<%# A ruled divider with a week selector in the middle. Changing it reloads %>
<%# with ?lb_week=N, which re-scopes the leaderboard and the verified list %>
<%# below it. Shows a static label when only one week exists. %>
<% weeks = @board_weeks || [] %>
<% current = @board_week %>
<% if current %>
  <%# Same four-point sparkle the platform's section dividers use. %>
  <% star = capture do %>
    <svg class="raffle-weekpick__star" viewBox="206.75 4 28.5 38" aria-hidden="true" focusable="false">
      <path d="M219.878 4.56347C220.11 3.49747 221.63 3.49747 221.862 4.56347L224.565 16.998C224.635 17.3195 224.856 17.5872 225.159 17.7162L234.99 21.9063C235.813 22.257 235.813 23.4233 234.99 23.774L225.159 27.9642C224.856 28.0932 224.635 28.3609 224.565 28.6824L221.862 41.1169C221.63 42.1829 220.11 42.1829 219.878 41.1169L217.175 28.6824C217.105 28.3609 216.884 28.0932 216.581 27.9642L206.75 23.774C205.927 23.4233 205.927 22.257 206.75 21.9063L216.581 17.7162C216.884 17.5872 217.105 17.3195 217.175 16.998L219.878 4.56347Z" fill="currentColor" />
    </svg>
  <% end %>
  <div class="raffle-weekpick">
    <span class="raffle-weekpick__rule" aria-hidden="true"></span>
    <span class="raffle-weekpick__center">
      <%= star %>
      <% if weeks.size > 1 %>
        <form class="raffle-weekpick__form" method="get" action="<%= request.path %>">
          <% if @query.present? %><input type="hidden" name="q" value="<%= @query %>"><% end %>
          <label class="raffle-weekpick__label raffle-sr-only" for="lb_week_pick">Viewing week</label>
          <select id="lb_week_pick" name="lb_week" class="raffle-weekpick__select"
                  data-auto-submit autocomplete="off">
            <% weeks.each do |w| %>
              <option value="<%= w.number %>" <%= "selected" if w.number == current.number %>>Week <%= w.number %><%= w.status_active? ? " · current" : "" %></option>
            <% end %>
          </select>
        </form>
      <% else %>
        <span class="raffle-weekpick__label raffle-weekpick__label--static">Week <%= current.number %></span>
      <% end %>
      <%= star %>
    </span>
    <span class="raffle-weekpick__rule" aria-hidden="true"></span>
  </div>
<% end %>
